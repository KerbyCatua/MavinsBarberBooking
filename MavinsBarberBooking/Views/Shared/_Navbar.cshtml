@using System.Security.Claims

<head>
    <link href="~/css/shared/_Navbar.css" rel="stylesheet" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
</head>

<div class="bg-watermark">
    <img src="~/images/logos/mavins-tab-logo.webp" alt="Watermark Logo" asp-append-version="true" />
</div>

<nav class="navbar px-4 px-lg-5 py-4 d-flex justify-content-between align-items-center flex-wrap">

    <div class="d-flex align-items-center gap-3 gap-lg-4">
        <span class="fs-4 text-dark" style="cursor: pointer;">
            <partial name="_Sidebar" />
        </span>

        <a class="navbar-brand m-0 p-0" href="#">
            <img src="~/images/logos/mavins-full-logo.webp" alt="Mavins Logo" style="max-height: 45px;" />
        </a>
    </div>

    <div class="nav-links-container d-flex align-items-center justify-content-center gap-3 gap-lg-4 fw-bold flex-wrap mt-3 mt-lg-0">
        <a asp-controller="Home" asp-action="Index" class="text-dark text-decoration-none custom-nav-link">Home</a>
        <a asp-controller="Barber" asp-action="Index" class="text-dark text-decoration-none custom-nav-link">Team</a>
        <a asp-controller="Service" asp-action="Index" class="text-dark text-decoration-none custom-nav-link">Services</a>
        @* <a asp-controller="Home" asp-action="About" class="text-dark text-decoration-none custom-nav-link">About</a> *@
        @* <a asp-controller="#" asp-action="#" class="text-dark text-decoration-none custom-nav-link">Gallery</a> *@

        @* TODO *@
        @* @if (User.IsInRole("Admin"))
        {
            <p>Hello Admin, @User.FindFirst(ClaimTypes.Name)?.Value</p>   
        } *@

        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            var firstName = User.FindFirst(ClaimTypes.GivenName)?.Value;
            var lastName = User.FindFirst(ClaimTypes.Surname)?.Value;

            <div class="d-flex align-items-center gap-2 text-dark custom-nav-link">
                <i class="fa-regular fa-user profile-icon"></i>
                <div class="d-flex flex-column" style="line-height: 1.2;">
                    <span class="fw-bold profile-last">Hello, @lastName</span>
                    <span class="profile-first" style="font-weight: 500;">@firstName</span>
                </div>
            </div>
        }
        else
        {
            <button onclick="window.location.href='#'" class="btn rounded-0 px-4 py-2 fw-bold custom-dark-btn text-white">BOOK NOW</button>
        }
    </div>
</nav>