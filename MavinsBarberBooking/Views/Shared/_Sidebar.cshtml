@using System.Security.Claims

<link href="~/css/shared/_Sidebar.css" rel="stylesheet" asp-append-version="true" />

<div id="sidebarOverlay" class="sidebar-overlay" onclick="toggleSidebar()"></div>

<i class="fa-solid fa-bars" onclick="toggleSidebar()" style="cursor: pointer; font-size: 1.5rem;"></i>

<div id="mySidebar" class="custom-sidebar">
    <i class="fa-solid fa-xmark close-btn" onclick="toggleSidebar()"></i>

    <div class="sidebar-content-wrapper">
        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            @* LOGGED IN USER VIEW *@
            var fullName = User.FindFirst(ClaimTypes.Name)?.Value;
            var email = User.FindFirst(ClaimTypes.Email)?.Value;
            var role = User.FindFirst(ClaimTypes.Role)?.Value;
            role = role == "Customer" ? "" : role;

            <div class="user-profile-section">
                <i class="fa-regular fa-user profile-icon"></i>
                <div class="user-details">
                    @if (!string.IsNullOrEmpty(role))
                    {
                        <span class="user-role">@role</span>
                    }
                    <span class="user-name">@fullName</span>
                    <span class="user-email">@email</span>
                </div>
            </div>

            <hr class="sidebar-divider" />

            <div class="sidebar-nav-links">
                @{
                    var RouteUserProfile = User.FindFirst(ClaimTypes.Role)?.Value switch
                    {
                        "Admin" => "/Admin/Index", // to be updated to /Admin/Profile when the profile page is created
                        "Barber" => "/Barber/Profile",
                        "Customer" => "/Customer/Profile",
                        _ => ""
                    };
                }
                <a href="@RouteUserProfile">Profile</a>
                <a href="#">Notifications</a>
                <a href="#">Settings</a>
                <a href="/#gallery-section" onclick="toggleSidebar()">Gallery</a>
                <a href="#" onclick="copyUrlAndNotify(event)">Share</a>
            </div>

            <hr class="sidebar-divider" />

            <form asp-controller="Account" asp-action="Logout" method="post" class="logout-form">
                <button type="submit" class="logout-btn">
                    <i class="fa-solid fa-arrow-right-from-bracket"></i> Log Out
                </button>
            </form>
        }
        else
        {
            @* LOGGED OUT (GUEST) VIEW *@
            <div class="user-profile-section">
                <i class="fa-regular fa-user profile-icon"></i>
                <div class="user-details">
                    <span class="user-name">Welcome, Guest</span>
                    <span class="user-email">Sign in to book a haircut</span>
                </div>
            </div>

            <hr class="sidebar-divider" />

            <div class="sidebar-nav-links">
                <a href="/Service/Index">Services</a>
                <a href="/Barber/Index">Our Barbers</a>
                <a href="/#gallery-section" onclick="toggleSidebar()">Gallery</a>
                <a href="#" onclick="copyUrlAndNotify(event)">Share</a>
            </div>

            <hr class="sidebar-divider" />

            <div class="sidebar-auth-links">
                <a asp-controller="Account" asp-action="Login">Log In</a>
                <a asp-controller="Account" asp-action="Register">Register</a>
            </div>
        }

        <div class="sidebar-footer">
            @* <div class="social-icons">
                <i class="fa-brands fa-instagram"></i>
                <i class="fa-brands fa-facebook-f"></i>
            </div> *@
            <div class="location-info">
                <i class="fa-solid fa-location-dot"></i>
                <p>
                    #78 Mavins Barbershop, Gonzales Ave. San Juan, Apalit, Pampanga 2016
                </p>
            </div>
        </div>
    </div>
</div>

<script>
    function toggleSidebar() {
        var sidebar = document.getElementById("mySidebar");
        var overlay = document.getElementById("sidebarOverlay");

        sidebar.classList.toggle("open");
        overlay.classList.toggle("active");
    }

    function copyUrlAndNotify(e) {
        e.preventDefault(); // Prevent page from jumping to top

        // Get the base URL of your site
        var siteUrl = window.location.origin;

        // Copy to clipboard
        navigator.clipboard.writeText(siteUrl).then(function () {
            // Once copied, redirect to the server to set TempData and reload
            var currentPath = window.location.pathname + window.location.search;
            window.location.href = '/Home/ShareLink?returnUrl=' + encodeURIComponent(currentPath);
        }).catch(function(err) {
            console.error('Could not copy text: ', err);
        });
    }
</script>