@{
    ViewData["Title"] = "Restricted for Barber";
    Layout = "_AuthLayout";
}

<style>
    .text-dark-custom {
        color: white;
        font-weight: 700;
        letter-spacing: -1px;
    }

    .text-muted-custom {
        color: rgba(255,255,255,0.8);
        font-size: 1.1rem;
        line-height: 1.6;
        max-width: 450px;
    }

    .btn-dark-custom {
        background-color: black;
        color: white;
        border-radius: 5px;
        font-weight: 600;
        padding: 12px 30px;
        transition: all 0.3s ease;
        border: none;
        text-decoration: none;
        display: inline-block;
    }

        .btn-dark-custom:hover {
            transform: translateY(-2px);
            background-color: #1a1a1a;
            color: white;
        }

    .decor {
        position: absolute;
        stroke: black;
        pointer-events: none;
        opacity: 0.6;
    }
</style>

<main class="min-vh-100 d-flex align-items-center justify-content-center position-relative overflow-hidden">
    <div class="position-absolute w-100 h-100" style="pointer-events: none;">
        <svg class="decor" style="top:10%; left:10%; width:80px;" viewBox="0 0 100 100" fill="none" stroke-width="4"><circle cx="50" cy="50" r="48" /></svg>
        <svg class="decor" style="bottom:20%; right:10%; width:40px;" viewBox="0 0 24 24" fill="none" stroke-width="6"><line x1="4" y1="4" x2="20" y2="20"></line><line x1="20" y1="4" x2="4" y2="20"></line></svg>
    </div>

    <div class="container z-1">
        <div class="row align-items-center justify-content-center">
            <div class="col-md-5 d-flex justify-content-center pe-md-5 mb-5 mb-md-0">
                <svg width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6 3v12" />
                    <path d="M18 3v12" />
                    <path d="M3 7h18" />
                    <path d="M3 11h18" />
                    <path d="M6 15a6 6 0 0 0 12 0" />
                </svg>
            </div>
            <div class="col-md-7 text-center text-md-start">
                <h1 class="display-4 text-dark-custom mb-3">Access restricted for barbers</h1>
                <p class="text-muted-custom mb-4 mx-auto mx-md-0">
                    It looks like you're trying to access a section that is not available to barbers.
                    Please check your station or the barber dashboard for your upcoming appointments.
                </p>
                <a href="/Barber/Profile" class="btn btn-dark-custom">Go to Barber Dashboard</a>
            </div>
        </div>
    </div>
</main>