@model MavinsBarberBooking.Models.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login";
    Layout = "_AuthLayout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/account/Login.css" asp-append-version="true" />
}

<div class="login-background">

    <img src="~/images/logos/mavins-line.webp" class="mavins-line" /> @* Its more than just a haircut image *@

    <img src="~/images/logos/mavins-tab-logo.webp" class="mavins-tab-logo" asp-append-version="true" />  @* M logo image  *@ 

    <div class="login-card">
        <div class="mb-4 reveal-element">
            <h5 class="fw-bold mb-1 fs-6">Welcome!</h5>
            <h2 class="fw-bold mb-1">Sign in to</h2>
            <p class="text-dark small fw-semibold">Mavins Barber Shop</p>
        </div>

        <form asp-action="Login" asp-controller="Account" method="post">

            <div class="mb-3 reveal-element">
                <label asp-for="Email" class="form-label fw-bold small mb-1">Email</label>

                <input asp-for="Email"
                       type="email"
                       class="form-control form-control-custom"
                       placeholder="Enter your email" />

                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3 reveal-element">
                <label asp-for="Password" class="form-label fw-bold small mb-1">Password</label>

                <div class="position-relative">
                    <input asp-for="Password"
                           type="password"
                           class="form-control form-control-custom pe-5"
                           placeholder="Enter your Password"
                           id="passwordInput" />

                    <button type="button"
                            class="btn btn-link position-absolute top-50 end-0 translate-middle-y pe-3 password-toggle-btn"
                            id="togglePassword"
                            aria-label="Toggle password visibility">

                        <i class="fa-solid fa-eye-slash text-muted"></i>
                    </button>
                </div>

                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-4 small reveal-element">
                <div class="form-check">
                    <input type="checkbox"
                           class="form-check-input shadow-none"
                           id="rememberMe">

                    <label class="form-check-label text-muted"
                           for="rememberMe"
                           style="font-size: 0.8rem;">
                        Remember me
                    </label>
                </div>

                <a href="#"
                   class="text-muted text-decoration-none"
                   style="font-size: 0.8rem;">
                    Forgot Password ?
                </a>
            </div>

            <button type="submit"
                    class="btn btn-dark w-100 py-2 mb-4 reveal-element"
                    style="border-radius: 6px; font-weight: 500;">
                Login
            </button>

            <div class="text-center small reveal-element">
                <span class="text-muted">Don't have an Account ? </span>
                <a href="/Account/Register"
                   class="text-dark fw-bold text-decoration-none">
                    Register
                </a>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/account/Login.js" asp-append-version="true"></script>
}