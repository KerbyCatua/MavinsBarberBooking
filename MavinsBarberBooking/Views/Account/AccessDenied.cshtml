@{
    ViewData["Title"] = "Access Denied";
    Layout = "_AuthLayout";
}

@section Styles {
    <link href="~/css/account/AccessDenied.css" rel="stylesheet" asp-append-version="true" />
}

@section Scripts { 

}

<main class="access-denied-bg min-vh-100 d-flex align-items-center justify-content-center position-relative overflow-hidden">

    <div aria-hidden="true" class="bg-decorations">
        <svg class="decor circle c-1" viewBox="0 0 100 100" fill="none" stroke="#0B1021" stroke-width="4"><circle cx="50" cy="50" r="48" /></svg>
        <svg class="decor circle c-2" viewBox="0 0 100 100" fill="none" stroke="#0B1021" stroke-width="4"><circle cx="50" cy="50" r="48" /></svg>
        <svg class="decor circle c-3" viewBox="0 0 100 100" fill="none" stroke="#0B1021" stroke-width="4"><circle cx="50" cy="50" r="48" /></svg>

        <svg class="decor cross x-1 reveal-element" viewBox="0 0 24 24" fill="none" stroke="#0B1021" stroke-width="6" stroke-linecap="round"><line x1="4" y1="4" x2="20" y2="20"></line><line x1="20" y1="4" x2="4" y2="20"></line></svg>
        <svg class="decor cross x-2" viewBox="0 0 24 24" fill="none" stroke="#0B1021" stroke-width="6" stroke-linecap="round"><line x1="4" y1="4" x2="20" y2="20"></line><line x1="20" y1="4" x2="4" y2="20"></line></svg>
        <svg class="decor cross x-3" viewBox="0 0 24 24" fill="none" stroke="#0B1021" stroke-width="6" stroke-linecap="round"><line x1="4" y1="4" x2="20" y2="20"></line><line x1="20" y1="4" x2="4" y2="20"></line></svg>
    </div>

    <div class="container z-1">
        <div class="row align-items-center justify-content-center">

            <div class="col-md-5 d-flex justify-content-center justify-content-md-end pe-md-5 mb-5 mb-md-0">
                <div class="plug-illustration">
                    <svg viewBox="0 0 200 150" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M10,140 Q40,40 90,80 T130,80" stroke="#0B1021" stroke-width="4" fill="none" stroke-linecap="round" />
                        <path d="M190,10 Q160,110 110,70 T70,70" stroke="#0B1021" stroke-width="4" fill="none" stroke-linecap="round" />
                        <rect x="120" y="65" width="25" height="30" rx="4" fill="#0B1021" />
                        <rect x="145" y="72" width="10" height="4" fill="#0B1021" />
                        <rect x="145" y="84" width="10" height="4" fill="#0B1021" />
                        <path d="M60 65 H80 V95 H60 A10 10 0 0 1 50 85 V75 A10 10 0 0 1 60 65 Z" fill="#0B1021" />
                        <line x1="100" y1="40" x2="105" y2="55" stroke="#0B1021" stroke-width="3" stroke-linecap="round" />
                        <line x1="100" y1="120" x2="105" y2="105" stroke="#0B1021" stroke-width="3" stroke-linecap="round" />
                        <line x1="115" y1="30" x2="115" y2="45" stroke="#0B1021" stroke-width="3" stroke-linecap="round" />
                        <line x1="85" y1="30" x2="85" y2="45" stroke="#0B1021" stroke-width="3" stroke-linecap="round" />
                    </svg>
                </div>
            </div>

            <div class="col-md-7 text-center text-md-start">
                <h1 class="fw-bold display-4 text-dark-custom mb-3">Access Denied</h1>
                <p class="text-muted-custom mb-4 mx-auto mx-md-0">
                    You do not have permission to view this page. <br class="d-none d-md-block" />
                    If you believe this is an error, please contact support.
                </p>

                <div class="d-flex flex-column flex-sm-row align-items-center justify-content-center justify-content-md-start gap-3">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-dark-custom px-4 py-2">Return to Home</a>
                </div>
            </div>

        </div>
    </div>
</main>