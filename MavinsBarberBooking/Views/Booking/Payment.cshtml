@model MavinsBarberBooking.Models.ViewModels.PaymentViewModel
@{
    ViewData["Title"] = "Payment";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="row mb-4">
        <div class="col-12 text-center">
            <a href="javascript:history.back()" class="btn btn-sm btn-outline-dark rounded-0 mb-3 px-3 d-inline-flex align-items-center">
                <span class="me-2">&larr;</span> Back to Booking
            </a>
            <h2 class="fw-bold text-dark mb-1">Payment</h2>
            <p class="text-muted small">Mavins Barber Booking</p>
        </div>
    </div>

    <div class="row justify-content-center">
        <!-- Order Summary Card -->
        <div class="col-md-6 col-lg-5 col-xl-4 mb-4">
            <div class="card bg-secondary text-white rounded-0 shadow-sm h-100 border-0">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-light pb-2">
                        <h5 class="mb-0 fw-bold text-uppercase">Order Summary</h5>
                        <span class="badge border border-light text-light rounded-0 px-2 py-1 text-uppercase" style="font-size: 0.65rem;">
                            <span class="spinner-grow spinner-grow-sm me-1" role="status" style="width: 0.4rem; height: 0.4rem;"></span>
                            Awaiting Payment
                        </span>
                    </div>

                    <div class="d-flex justify-content-between mb-3 border-bottom border-light border-opacity-25 pb-2">
                        <span class="small text-white-50">Service:</span>
                        <span class="fw-medium text-end">@Model.ServiceName</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3 border-bottom border-light border-opacity-25 pb-2">
                        <span class="small text-white-50">Barber:</span>
                        <span class="fw-medium text-end">@Model.BarberName</span>
                    </div>

                    <!-- Fee Breakdown -->
                    <div class="d-flex justify-content-between mb-1 mt-4">
                        <span class="small text-white-50">Downpayment:</span>
                        <span class="small">₱ @Model.BaseAmount.ToString("0.00")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3 border-bottom border-light border-opacity-25 pb-2">
                        <span class="small text-white-50">Processing Fee (0.0%):</span>
                        <span class="small">₱ @Model.FeeAmount.ToString("0.00")</span>
                    </div>

                    <div class="d-flex justify-content-between mt-3 align-items-center">
                        <span class="fw-bold text-uppercase fs-5">Total Due:</span>
                        <span class="fw-bold fs-3">₱ @Model.TotalAmount.ToString("0.00")</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Payment Instructions Card -->
        <div class="col-md-6 col-lg-5 col-xl-4 mb-4">
            <div class="card bg-light border-0 rounded-0 shadow-sm h-100">
                <div class="card-body text-center p-4">
                    <h4 class="fw-bold mb-2">Pay Via GCash</h4>
                    <p class="text-muted small mb-4">Click the button below to proceed to the secure PayMongo GCash portal.</p>

                    <!-- Secure Notice -->
                    <div class="bg-white border border-dark border-opacity-25 p-3 mb-4 text-start shadow-sm">
                        <div class="d-flex align-items-center mb-1">
                            <i class="bi bi-clock-history me-2 text-dark"></i>
                            <span class="fw-bold text-dark text-uppercase small" style="letter-spacing: 0.5px;">Link Validity</span>
                        </div>
                        <h6 class="fw-bold text-dark mb-1 ms-4">Valid for 24 Hours</h6>
                        <p class="text-muted small mb-0 ms-4" style="font-size: 0.75rem;">Please complete the payment within this timeframe to secure your slot.</p>
                    </div>

                    <div class="d-grid gap-3">
                        <!-- THE BUTTON THAT GOES TO PAYMONGO -->
                        <a href="@Model.CheckoutUrl" class="btn btn-dark rounded-0 fw-bold py-3 fs-5 shadow">
                            Proceed to GCash
                        </a>
                        <a href="/Home/Index" class="btn btn-outline-dark rounded-0 py-2">
                            Cancel Booking
                        </a>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>