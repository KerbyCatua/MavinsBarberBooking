@model MavinsBarberBooking.Controllers.BookingViewModel

@{
    ViewData["Title"] = "Book Appointment";
    Layout = "_Layout";

    // Used to parse hours logic out later
    var durationDisplay = Model.DurationMinutes >= 60
        ? $"{Model.DurationMinutes / 60} hr " + (Model.DurationMinutes % 60 > 0 ? $"{Model.DurationMinutes % 60} min" : "")
        : $"{Model.DurationMinutes} min";
}

<div class="container-fluid px-4 px-lg-5 pt-2 pb-5">
    <div class="mx-auto" style="max-width: 1200px;">
        <h1 class="display-4 fw-bolder text-dark mb-4" style="letter-spacing: -2px;">Book Appointment</h1>

        <div class="row g-4">
            <!-- Left Column: Calendar & Time Selection -->
            <div class="col-lg-7">
                <div class="glass-panel p-4 text-white d-flex flex-column h-100">
                    <h4 class="fw-bold mb-4 fs-5 d-flex align-items-center gap-2">
                        <i class="fa-regular fa-calendar"></i> @Model.ServiceName by @Model.BarberName
                    </h4>

                    <div class="row flex-grow-1">
                        <!-- Calendar Section -->
                        <div class="col-md-7 mb-4 mb-md-0 border-end border-secondary border-opacity-25 pe-md-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h3 class="m-0 fs-4 fw-bold" id="currentMonthYear"></h3>
                                <div>
                                    <button class="btn btn-sm text-white" onclick="changeMonth(-1)"><i class="fa-solid fa-chevron-left"></i></button>
                                    <button class="btn btn-sm text-white" onclick="changeMonth(1)"><i class="fa-solid fa-chevron-right"></i></button>
                                </div>
                            </div>

                            <table class="table table-borderless text-center text-white calendar-table">
                                <thead>
                                    <tr class="opacity-75">
                                        <th>M</th>
                                        <th>T</th>
                                        <th>W</th>
                                        <th>T</th>
                                        <th>F</th>
                                        <th>S</th>
                                        <th>S</th>
                                    </tr>
                                </thead>
                                <tbody id="calendarBody">
                                    <!-- Calendar days will be generated by JS -->
                                </tbody>
                            </table>
                        </div>

                        <!-- Time Slots Section -->
                        <div class="col-md-5 ps-md-4">
                            <h4 class="fs-6 fw-bold mb-3 text-center opacity-75" id="selectedDateDisplay"></h4>
                            <div id="timeSlotsContainer" class="d-flex flex-column gap-2 overflow-auto" style="max-height: 250px;">
                                <!-- Time slots generated by JS -->
                            </div>

                            <!-- Action button (Hidden until time is selected) -->
                            <div class="mt-4 text-center d-none" id="confirmTimeContainer">
                                <form method="get" action="/Booking/Confirm">
                                    <input type="hidden" name="serviceId" value="@Model.ServiceId" />
                                    <input type="hidden" name="barberId" value="@Model.BarberId" />
                                    <input type="hidden" name="selectedDate" id="hiddenSelectedDate" />
                                    <input type="hidden" name="selectedTime" id="hiddenSelectedTime" />
                                    <button type="submit" class="btn btn-light w-100 fw-bold rounded-pill text-dark">Confirm</button>
                                </form>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 pt-3 border-top border-secondary border-opacity-25">
                        <label class="form-label small fw-bold mb-1 opacity-75">Time zone</label>
                        <select class="form-select form-select-sm bg-transparent text-white border-secondary rounded-3" style="width: auto; cursor: pointer;">
                            <option value="PH" class="text-dark">Philippines - Manila</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- Right Column: Summary -->
            <div class="col-lg-5 d-flex flex-column gap-4">
                <!-- Shop Info -->
                <div class="glass-panel p-4 text-center text-white">
                    <img src="~/images/gallery/gallery-image-mavins-logo.webp" alt="Mavins Barbershop Logo" class="rounded-circle mb-3 bg-white p-1" style="width: 120px; height: 120px; object-fit: cover;">
                    <h2 class="fw-bold fs-3 mb-2">Mavins Barbershop</h2>
                    <a href="#" class="text-white opacity-75 small text-decoration-underline lh-base d-inline-block px-3">
                        #78 Mavins Barbershop, Gonzales Ave., San Juan,<br>Apalit, Pampanga Apalit, Pampanga 2016
                    </a>
                </div>

                <!-- Booking Summary -->
                <div class="glass-panel p-4 text-white flex-grow-1">
                    <h2 class="fw-bold fs-4 mb-4">Summary</h2>

                    <div class="d-flex justify-content-between align-items-start mb-1">
                        <div>
                            <p class="mb-0 fw-medium">@Model.ServiceName by @Model.BarberName</p>
                            <p class="small opacity-75 mb-0">@durationDisplay &middot; with Barber-@Model.BarberName</p>
                        </div>
                        <span class="fw-bold">&#8369;@Model.Price.ToString("0")</span>
                    </div>

                    <hr class="border-secondary my-4">

                    <div class="d-flex justify-content-between align-items-center fw-bold fs-5">
                        <span>Total to pay</span>
                        <span>&#8369;@Model.Price.ToString("0")</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .glass-panel {
        background: rgba(80, 80, 80, 0.4);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 15px;
        box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
    }

    .calendar-table th, .calendar-table td {
        width: 14.28%;
        padding: 8px 0;
        vertical-align: middle;
        background: transparent !important;
        color: white;
    }

    .calendar-day {
        width: 35px;
        height: 35px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        cursor: pointer;
        transition: all 0.2s ease;
    }

        .calendar-day:hover:not(.empty):not(.selected) {
            background: rgba(255, 255, 255, 0.2);
        }

        .calendar-day.selected {
            background: white;
            color: black !important;
            font-weight: bold;
        }

        .calendar-day.empty {
            cursor: default;
            opacity: 0.3;
        }

    .time-slot {
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.3);
        color: white;
        border-radius: 8px;
        padding: 10px;
        text-align: center;
        cursor: pointer;
        transition: all 0.2s ease;
        font-weight: 500;
        font-size: 0.9em;
    }

        .time-slot:hover {
            background: rgba(255, 255, 255, 0.2);
        }

        .time-slot.selected {
            background: white;
            color: black;
            border-color: white;
        }
</style>

@section Scripts {
    <script>
        const serverTimeSlots = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TimeSlots));

        const months = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];
        let currentDate = new Date();
        let selectedDateDisplay = new Date();

        function renderCalendar() {
            const year = currentDate.getFullYear();
            const month = currentDate.getMonth();
            document.getElementById("currentMonthYear").innerText = `${months[month]} ${year}`;

            const firstDay = new Date(year, month, 1).getDay();
            const daysInMonth = new Date(year, month + 1, 0).getDate();
            const daysInPrevMonth = new Date(year, month, 0).getDate();

            let startDay = firstDay === 0 ? 6 : firstDay - 1;

            let html = "<tr>";
            let dayCount = 1;
            let nextMonthDay = 1;

            for (let i = 0; i < 42; i++) {
                if (i % 7 === 0 && i !== 0) html += "</tr><tr>";

                if (i < startDay) {
                    html += `<td><span class="calendar-day empty">${daysInPrevMonth - startDay + i + 1}</span></td>`;
                } else if (dayCount <= daysInMonth) {
                    let isSelected = selectedDateDisplay.getDate() === dayCount && selectedDateDisplay.getMonth() === month && selectedDateDisplay.getFullYear() === year;
                    let selectedClass = isSelected ? "selected" : "";
                    html += `<td><span class="calendar-day ${selectedClass}" onclick="selectDate(${year}, ${month}, ${dayCount})">${dayCount}</span></td>`;
                    dayCount++;
                } else {
                    html += `<td><span class="calendar-day empty">${nextMonthDay}</span></td>`;
                    nextMonthDay++;
                }
            }
            html += "</tr>";
            document.getElementById("calendarBody").innerHTML = html;
        }

        function changeMonth(dir) {
            currentDate.setMonth(currentDate.getMonth() + dir);
            renderCalendar();
        }

        function selectDate(year, month, day) {
            selectedDateDisplay = new Date(year, month, day);
            const options = { weekday: 'long', day: 'numeric', month: 'long' };
            document.getElementById("selectedDateDisplay").innerText = selectedDateDisplay.toLocaleDateString('en-GB', options);

            renderCalendar();
            fetchTimeSlotsForDate(selectedDateDisplay);
        }

        function fetchTimeSlotsForDate(date) {
            const timeSlotsContainer = document.getElementById("timeSlotsContainer");
            const confirmContainer = document.getElementById("confirmTimeContainer");
            timeSlotsContainer.innerHTML = "";
            confirmContainer.classList.add("d-none");

            // Ignore time portion for comparison
            const selectedDateMidnight = new Date(date.getFullYear(), date.getMonth(), date.getDate()).getTime();
            let hasSlots = false;

            serverTimeSlots.forEach(slot => {
                const slotStart = new Date(slot.StartTime);
                const slotEnd = new Date(slot.EndTime);
                const slotDateMidnight = new Date(slotStart.getFullYear(), slotStart.getMonth(), slotStart.getDate()).getTime();

                // If DB slot matches selected calendar Date
                if (slotDateMidnight === selectedDateMidnight) {
                    let currentTimestamp = slotStart.getTime();
                    const endTimestamp = slotEnd.getTime();
                    const intervalMs = 90 * 60 * 1000; // 1.5 hr interval chunking

                    // Loop through DB slot duration creating available chunks
                    while (currentTimestamp + intervalMs <= endTimestamp) {
                        hasSlots = true;
                        const chunkTime = new Date(currentTimestamp);

                        // Format display e.g. "12:00 PM"
                        const formatTime = (d) => {
                            let h = d.getHours();
                            let m = d.getMinutes();
                            let ampm = h >= 12 ? 'PM' : 'AM';
                            h = h % 12; h = h ? h : 12;
                            m = m < 10 ? '0'+m : m;
                            return `${h}:${m} ${ampm}`;
                        };

                        const timeStr = `${formatTime(chunkTime)}`;

                        const slotDiv = document.createElement("div");
                        slotDiv.className = "time-slot";
                        slotDiv.innerText = timeStr;
                        slotDiv.onclick = function() {
                            document.querySelectorAll('.time-slot').forEach(el => el.classList.remove('selected'));
                            slotDiv.classList.add('selected');

                            // Get local date format to prevent timezone offset bugs
                            const localYear = date.getFullYear();
                            const localMonth = String(date.getMonth() + 1).padStart(2, '0');
                            const localDay = String(date.getDate()).padStart(2, '0');

                            // Set hidden input values for the form
                            document.getElementById('hiddenSelectedDate').value = `${localYear}-${localMonth}-${localDay}`;
                            document.getElementById('hiddenSelectedTime').value = timeStr;

                            confirmContainer.classList.remove('d-none');
                        };

                        timeSlotsContainer.appendChild(slotDiv);
                        currentTimestamp += intervalMs;
                    }
                }
            });

            if(!hasSlots) {
                timeSlotsContainer.innerHTML = "<p class='text-center opacity-75'>No availability on this date.</p>";
            }
        }

        // Initialize display
        document.addEventListener("DOMContentLoaded", () => {
            renderCalendar();
            selectDate(selectedDateDisplay.getFullYear(), selectedDateDisplay.getMonth(), selectedDateDisplay.getDate());
        });
    </script>
}