@{
    ViewData["Title"] = "Home Page";
    Layout = "_Layout";
}

@section Scripts {
    <link rel="stylesheet" href="~/css/home/Index.css" asp-append-version="true" />
    <script src="~/js/home/Index.js" asp-append-version="true"></script>
}

        <div class="container-fluid px-5 py-5 mt-5">
            <div class="row">
                <div class="col-md-7 reveal-element">
                    <h1 class="display-2 fw-bolder hero-title mb-0">Mavins</h1>
                    <h1 class="display-2 fw-bolder hero-title">Barbershop</h1>

                    <p class="hero-subtitle mt-4 fs-5">
                        Welcome to Mavins Barbershop. Our Barbers are skilled professionals specializing
                        in men’s hair care. We offer a variety of services, including haircuts, Anti dandruff
                        treatment, shaves, Hair color & styling.
                    </p>

                    <div class="mt-5 d-flex gap-3">
                        <button onclick="window.location.href='/Barber/Index'" class="btn rounded-0 px-4 py-3 fw-bold fs-5 custom-dark-btn text-white">BOOK NOW</button>
                        @if (!(User.Identity != null && User.Identity.IsAuthenticated))
                        {
                            <button onclick="window.location.href='/Account/Login'" class="btn rounded-0 px-4 py-3 fw-bold fs-5 custom-dark-btn text-white">LOG IN</button>
                        }
                    </div>
                </div>
            </div>
        </div>

        <section id="gallery-section" class="container-fluid px-5 py-5 mt-5">

            <div class="mb-5 reveal-element">
                <p class="fw-bold text-uppercase mb-2 text-white" style="letter-spacing: 1px; font-size: 0.9rem;">
                    Our Masterpieces
                </p>
                <h2 class="display-4 fw-bolder text-dark lh-1 mb-0" style="letter-spacing: -2px;">
                    Everything you need to
                </h2>
                <h2 class="display-4 fw-bolder text-dark lh-1" style="letter-spacing: -2px;">
                    find your next style
                </h2>
            </div>

            <div class="row g-4">

                <div class="col-12 col-lg-7 reveal-element">
                    <div class="bento-box shadow-sm">
                        <div id="galleryCarousel" class="carousel slide carousel-fade h-100" data-bs-ride="carousel">
                            <div class="carousel-inner h-100">
                                <div class="carousel-item active h-100" data-bs-interval="1750">
                                    <img src="~/images/gallery/gallery-image-mavins-logo.webp" class="w-100 h-100 object-fit-cover" alt="Mavins Style 1" />
                                </div>
                                <div class="carousel-item h-100" data-bs-interval="1750">
                                    <img src="~/images/gallery/gallery-image-2.webp" class="w-100 h-100 object-fit-cover" alt="Mavins Style 2" />
                                </div>
                                <div class="carousel-item h-100" data-bs-interval="1750">
                                    <img src="~/images/gallery/gallery-image-3.webp" class="w-100 h-100 object-fit-cover" alt="Mavins Style 3" />
                                </div>
                                <div class="carousel-item h-100" data-bs-interval="1750">
                                    <img src="~/images/gallery/gallery-image-4.webp" class="w-100 h-100 object-fit-cover" alt="Mavins Style 4" />
                                </div>
                                <div class="carousel-item h-100" data-bs-interval="1750">
                                    <img src="~/images/gallery/gallery-image-5.webp" class="w-100 h-100 object-fit-cover" alt="Mavins Style 5" />
                                </div>
                                <div class="carousel-item h-100" data-bs-interval="1750">
                                    <img src="~/images/gallery/gallery-image-6.webp" class="w-100 h-100 object-fit-cover" alt="Mavins Style 6" />
                                </div>
                                <div class="carousel-item h-100" data-bs-interval="1750">
                                    <img src="~/images/gallery/gallery-image-7.webp" class="w-100 h-100 object-fit-cover" alt="Mavins Style 7" />
                                </div>
                                <div class="carousel-item h-100" data-bs-interval="1750">
                                    <img src="~/images/gallery/gallery-image-8.webp" class="w-100 h-100 object-fit-cover" alt="Mavins Style 8" />
                                </div>
                                <div class="carousel-item h-100" data-bs-interval="1750">
                                    <img src="~/images/gallery/gallery-image-9.webp" class="w-100 h-100 object-fit-cover" alt="Mavins Style 9" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-lg-5 reveal-element">
                    <div class="bento-box shadow-sm">
                        <img src="~/images/gallery/gallery-image-3.webp" class="w-100 h-100 object-fit-cover" alt="Static Style 1" />
                    </div>
                </div>

                <div class="col-12 col-lg-4 reveal-element">
                    <div class="bento-box shadow-sm">
                        <img src="~/images/gallery/gallery-image-6.webp" class="w-100 h-100 object-fit-cover" alt="Static Style 2" />
                    </div>
                </div>

                <div class="col-12 col-lg-8 reveal-element">
                    <div class="bento-box shadow-sm">
                        <img src="~/images/gallery/gallery-image-8.webp" class="w-100 h-100 object-fit-cover" alt="Static Style 3" />
                    </div>
                </div>

            </div>

        </section>